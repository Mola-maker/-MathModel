# Version control
.git
.gitignore

# Secrets — mounted read-only at runtime via docker-compose
.env

# Large reference data — not needed inside the image
gitclone/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Runtime-generated directories — provided via bind mounts at runtime
vol/
context_store/
paper/
translation/
knowledge_base/experience_log.json

# Logs
*.log

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db
